type User {
    id: ID!
    username: String!
    email: String!
    status: String!
    createdAt: String!
    updatedAt: String!
    roles: [Role]
}

type UserPage {
    data: [User]
    totalElements: Int
    totalPages: Int
}

extend type Query {
    getUserById(id: ID!): User
    getAllUsers(page: Int = 0, size: Int = 10): UserPage
}
